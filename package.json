{
  "name": "@interop/http-client",
  "description": "An opinionated, isomorphic HTTP client for Node.js, browsers, and React Native.",
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run lint && pnpm run test-node && pnpm run test-browser",
    "test-browser": "playwright test",
    "test-node": "vitest run",
    "test-coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.browser.js",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": "dist/index.browser.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "ky": "^1.0.1",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cors": "^2.8.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^4.18.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "http",
    "isomorphic",
    "http client"
  ],
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/http-client.git"
  },
  "homepage": "https://github.com/interop-alliance/http-client",
  "bugs": "https://github.com/interop-alliance/http-client/issues"
}
